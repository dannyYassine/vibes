{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weather",
  "version": "0.1.0",
  "identifier": "com.weather.app",
  "build": {
    "frontendDist": "../frontend/dist/frontend/browser",
    "devUrl": "http://localhost:4200"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Weather",
        "width": 600,
        "height": 900,
        "minWidth": 500,
        "minHeight": 750,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
